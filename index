<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Impress Hotel - Monthly Statistics Dashboard</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7f6; padding: 20px; color: #2c3e50; margin: 0; }
        .container { max-width: 1200px; margin: 0 auto; }
        
        /* Header & Upload Zone */
        .header-section { text-align: center; background: #ffffff; padding: 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-bottom: 25px; border-top: 8px solid #2980b9; }
        .header-section h2 { margin: 0 0 10px 0; color: #2c3e50; font-size: 28px; }
        
        .upload-zone { border: 2px dashed #3498db; background-color: #f0f8ff; padding: 30px; border-radius: 8px; cursor: pointer; transition: background 0.3s; margin-top: 20px; }
        .upload-zone:hover { background-color: #e1f0fa; }
        .upload-zone p { font-size: 18px; color: #2980b9; font-weight: bold; margin: 0; }
        #fileInput { display: none; }

        /* MTD (Month-to-Date) Summary */
        .section-title { font-size: 20px; font-weight: bold; margin: 30px 0 15px 0; color: #34495e; border-bottom: 2px solid #bdc3c7; padding-bottom: 5px; }
        
        .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; }
        .kpi-card { background: #ffffff; padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.04); border-left: 5px solid #2ecc71; }
        .kpi-title { font-size: 14px; color: #7f8c8d; text-transform: uppercase; font-weight: bold; margin-bottom: 5px; }
        .kpi-value { font-size: 32px; font-weight: 900; color: #2c3e50; }
        
        .kpi-rev { border-color: #27ae60; }
        .kpi-rev .kpi-value { color: #27ae60; }
        .kpi-sold { border-color: #e67e22; }
        .kpi-sold .kpi-value { color: #e67e22; }
        .kpi-occ { border-color: #3498db; }
        .kpi-occ .kpi-value { color: #3498db; }
        .kpi-adr { border-color: #9b59b6; }
        .kpi-adr .kpi-value { color: #9b59b6; }

        /* Daily Selector */
        .daily-controls { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.04); margin-top: 20px; display: flex; align-items: center; gap: 15px; }
        .date-dropdown { font-size: 18px; padding: 10px 15px; border: 2px solid #34495e; border-radius: 8px; outline: none; cursor: pointer; color: #2c3e50; font-family: inherit; font-weight: bold; }
        
        #dashboardContent { display: none; } /* ซ่อนไว้ก่อนจนกว่าจะอัปโหลดไฟล์ */
    </style>
</head>
<body>

<div class="container">
    <div class="header-section">
        <h2>📊 Manager Dashboard</h2>
        <p style="color: #7f8c8d; margin-bottom: 20px;">สรุปผลประกอบการรายวัน (Daily Statistics)</p>
        
        <label class="upload-zone" id="dropZone">
            <input type="file" id="fileInput" accept=".csv">
            <p>📁 คลิกที่นี่เพื่ออัปโหลดไฟล์ Report (.csv) หรือลากไฟล์มาวาง</p>
            <span id="fileNameDisplay" style="color: #666; font-size: 14px; display: block; margin-top: 10px;"></span>
        </label>
    </div>

    <div id="dashboardContent">
        
        <div class="section-title">🌟 สรุปยอดรวมสะสมของเดือนนี้ (Month-to-Date)</div>
        <div class="kpi-grid">
            <div class="kpi-card kpi-rev">
                <div class="kpi-title">Total Room Revenue</div>
                <div class="kpi-value" id="mtdRev">฿0</div>
            </div>
            <div class="kpi-card kpi-sold">
                <div class="kpi-title">Total Nights Sold</div>
                <div class="kpi-value" id="mtdSold">0</div>
            </div>
            <div class="kpi-card kpi-occ">
                <div class="kpi-title">Average Occ.</div>
                <div class="kpi-value" id="mtdOcc">0%</div>
            </div>
            <div class="kpi-card kpi-adr">
                <div class="kpi-title">Average ADR</div>
                <div class="kpi-value" id="mtdAdr">฿0</div>
            </div>
        </div>

        <div class="section-title">📅 เจาะลึกข้อมูลรายวัน (Daily Performance)</div>
        <div class="daily-controls">
            <label style="font-weight: bold; color: #34495e;">เลือกวันที่:</label>
            <select id="dateSelector" class="date-dropdown"></select>
        </div>

        <div class="kpi-grid" style="margin-top: 20px;">
            <div class="kpi-card kpi-rev">
                <div class="kpi-title">Daily Room Charges</div>
                <div class="kpi-value" id="dailyRev">฿0</div>
            </div>
            <div class="kpi-card kpi-sold">
                <div class="kpi-title">Daily Nights Sold</div>
                <div class="kpi-value" id="dailySold">0</div>
            </div>
            <div class="kpi-card kpi-occ">
                <div class="kpi-title">Daily Occupancy</div>
                <div class="kpi-value" id="dailyOcc">0%</div>
            </div>
            <div class="kpi-card kpi-adr">
                <div class="kpi-title">Daily RevPAR</div>
                <div class="kpi-value" id="dailyRevPar">฿0</div>
            </div>
        </div>
    </div>
</div>

<script>
    let reportData = [];

    // ฟังก์ชันจัดการตัวเลขให้มีคอมม่า
    function formatMoney(amount) {
        return '฿' + amount.toLocaleString('th-TH', {minimumFractionDigits: 2, maximumFractionDigits: 2});
    }

    // ฟังก์ชันอ่านไฟล์ CSV เมื่อผู้ใช้อัปโหลด
    document.getElementById('fileInput').addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (!file) return;

        document.getElementById('fileNameDisplay').innerText = `กำลังประมวลผลไฟล์: ${file.name}`;
        
        const reader = new FileReader();
        reader.onload = function(event) {
            const csvText = event.target.result;
            processData(csvText);
        };
        reader.readAsText(file);
    });

    // ฟังก์ชันกรองขยะออกจากระบบ PMS และจัดเรียงข้อมูล
    function processData(csvText) {
        reportData = [];
        const rows = csvText.split('\n');

        for (let i = 0; i < rows.length; i++) {
            const line = rows[i].trim();
            if (line === '') continue;

            // ใช้ regex แยกคอลัมน์แบบรักษารูปแบบ
            const cols = line.match(/(\s*"[^"]+"\s*|\s*[^,]+|,)(?=,|$)/g);
            if (!cols) continue;
            const cleanCols = cols.map(m => m.replace(/^"|"$/g, '').trim()).filter(m => m !== ',');

            // ตรวจสอบว่าบรรทัดนี้คือ "ข้อมูลรายวัน" หรือไม่ 
            // โดยเช็กว่าคอลัมน์แรกเริ่มต้นด้วยตัวเลข (เช่น "1 Sun", "20 Fri")
            if (cleanCols.length > 10 && /^\d+/.test(cleanCols[0])) {
                reportData.push({
                    date: cleanCols[0],
                    sold: parseFloat(cleanCols[3]) || 0,
                    occ: parseFloat(cleanCols[5]) || 0,
                    adr: parseFloat(cleanCols[6]) || 0,
                    revPar: parseFloat(cleanCols[7]) || 0,
                    roomRev: parseFloat(cleanCols[10]) || 0
                });
            }
        }

        if (reportData.length > 0) {
            document.getElementById('dashboardContent').style.display = 'block';
            document.getElementById('fileNameDisplay').innerText = `อัปเดตข้อมูลล่าสุดเรียบร้อย! (พบข้อมูล ${reportData.length} วัน)`;
            
            calculateMTD();
            setupDailyDropdown();
        } else {
            alert('ไม่พบข้อมูลตัวเลขในไฟล์ โปรดตรวจสอบว่าใช่ไฟล์ Report (CSV) ที่ถูกต้องหรือไม่');
        }
    }

    // คำนวณยอดรวมสะสม (Month-to-Date)
    function calculateMTD() {
        let totalRev = 0, totalSold = 0, totalOcc = 0;
        
        reportData.forEach(day => {
            totalRev += day.roomRev;
            totalSold += day.sold;
            totalOcc += day.occ;
        });

        const avgOcc = (totalOcc / reportData.length).toFixed(2);
        const avgAdr = totalSold > 0 ? (totalRev / totalSold) : 0;

        document.getElementById('mtdRev').innerText = formatMoney(totalRev);
        document.getElementById('mtdSold').innerText = totalSold.toLocaleString('th-TH');
        document.getElementById('mtdOcc').innerText = avgOcc + '%';
        document.getElementById('mtdAdr').innerText = formatMoney(avgAdr);
    }

    // สร้างเมนูเลือกดูรายวัน
    function setupDailyDropdown() {
        const selector = document.getElementById('dateSelector');
        selector.innerHTML = '';

        // เรียงลำดับจากวันล่าสุดขึ้นก่อน (เผื่ออยากดูของเมื่อวาน)
        const reversedData = [...reportData].reverse();

        reversedData.forEach(day => {
            const option = document.createElement('option');
            option.value = day.date;
            option.textContent = day.date;
            selector.appendChild(option);
        });

        // แสดงข้อมูลของวันล่าสุดเป็นค่าเริ่มต้น
        showDailyData(reversedData[0].date);

        selector.addEventListener('change', (e) => {
            showDailyData(e.target.value);
        });
    }

    function showDailyData(selectedDate) {
        const dayData = reportData.find(d => d.date === selectedDate);
        if (dayData) {
            document.getElementById('dailyRev').innerText = formatMoney(dayData.roomRev);
            document.getElementById('dailySold').innerText = dayData.sold.toLocaleString('th-TH');
            document.getElementById('dailyOcc').innerText = dayData.occ.toFixed(2) + '%';
            document.getElementById('dailyRevPar').innerText = formatMoney(dayData.revPar);
        }
    }
</script>

</body>
</html>
